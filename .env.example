# OpenCode provider authentication is configured with `opencode auth login`.
# The variables below are needed only for the optional integrations you enable.

# Anthropic API (optional, only for routes that use it directly)
ANTHROPIC_API_KEY=your-key-here

# Obsidian Local REST API (optional state storage)
OBSIDIAN_REST_API_URL=https://localhost:27124
OBSIDIAN_REST_API_KEY=your-obsidian-api-key

# Substack publishing (for substack profiles)
SUBSTACK_PUBLICATION_URL=https://yourpub.substack.com
SUBSTACK_COOKIES_PATH=./cookies.json
SUBSTACK_USER_ID=your-user-id

# Image generation (optional, at least one needed for image agent)
FAL_API_KEY=your-fal-key
OPENAI_API_KEY=your-openai-key
IDEOGRAM_API_KEY=your-ideogram-key

# Comment scraping (optional)
DISQUS_API_KEY=your-disqus-key
DISQUS_USERNAME=your-disqus-username
